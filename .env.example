# ─────────────────────────────────────────────────────────────────────────────
# mm-data-hub environment
# Copy to `.env` and fill in. `.env` is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# FreshTrack GraphQL (dispatch domain, phase 1)
# The packhouse GraphQL endpoint. Auth header is sent verbatim as `Authorization`.
FRESHTRACK_GRAPHQL_URL=https://api.freshtrack.example/graphql
FRESHTRACK_AUTH_HEADER=Bearer REPLACE_ME

# Supabase hub — Postgres connection (loaders write to raw.* via pg, NOT PostgREST).
# Project `data_hub` (ref uqzfkhsdyeokwnkpcxui, ap-southeast-2). Prefer the SESSION POOLER
# (port 5432, user `postgres.<ref>`): the direct host db.<ref>.supabase.co is IPv6-only.
# Get it from: Supabase → Project Settings → Database → Connection string → Session pooler.
DATABASE_URL=postgres://postgres.uqzfkhsdyeokwnkpcxui:REPLACE_ME@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# Backfill window controls
BACKFILL_START=2025-07-01      # FY25-26 start (dispatched_at = actual_pickup_on)
BACKFILL_END=                  # blank = today (UTC)
WINDOW_DAYS=7                  # weekly windows; the FreshTrack API has filterLimit but no cursor
FRESHTRACK_FILTER_LIMIT=2000   # per-window safety cap; must exceed max rows in any single window

# Read-replica (GP/settlement domain) — PHASE 2, not used in phase 1.
# READONLY_DATABASE_URL=
