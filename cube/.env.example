# ─────────────────────────────────────────────────────────────────────────────
# Cube — LOCAL DEV ONLY (`cube dev` / Playground on this machine).
# In Cube Cloud these are configured in the deployment UI (Data Sources + Env vars),
# NOT from this file. Copy to cube/.env for local dev. Never commit cube/.env.
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing secret — MUST match the Cube Cloud deployment's CUBEJS_API_SECRET so tokens
# minted by the reconciliation / RLS proof scripts validate. Server-held; never shipped to growers.
CUBEJS_API_SECRET=replace_me

# Data source: the hub Postgres (data_hub, uqzfkhsdyeokwnkpcxui). Use a READ-ONLY role
# with SELECT on raw/core/semantic only (see supabase/migrations 0011). Session pooler host.
CUBEJS_DB_TYPE=postgres
CUBEJS_DB_HOST=aws-1-ap-southeast-2.pooler.supabase.com
CUBEJS_DB_PORT=5432
CUBEJS_DB_NAME=postgres
CUBEJS_DB_USER=cube_readonly.uqzfkhsdyeokwnkpcxui
CUBEJS_DB_PASS=replace_me
CUBEJS_DB_SSL=true

# Cube reads models from this folder layout (model/cubes, model/views).
CUBEJS_SCHEMA_PATH=model
