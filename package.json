{
  "name": "mm-data-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mackays Data Hub — FreshTrack ingestion into the Supabase hub (raw → core → semantic). Owns the raw/core/semantic schemas only.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "test:integration": "node --experimental-strip-types --test tests/integration/*.test.ts",
    "load:entities": "node --experimental-strip-types src/loaders/entities.ts",
    "load:dispatch": "node --experimental-strip-types src/loaders/dispatch.ts",
    "load:pallets": "node --experimental-strip-types src/loaders/pallets.ts",
    "backfill": "node --experimental-strip-types src/loaders/backfill.ts",
    "ft:db:smoke": "node --experimental-strip-types scripts/ft_db_smoke.ts",
    "ft:db:explore": "node --experimental-strip-types scripts/ft_db_explore.ts",
    "ft:db:gp-profile": "node --experimental-strip-types scripts/ft_db_gp_profile.ts",
    "ft:db:charge-profile": "node --experimental-strip-types scripts/ft_db_charge_profile.ts",
    "ft:dispatch:recon": "node --experimental-strip-types scripts/ft_dispatch_recon.ts",
    "ft:dispatch:load": "node --experimental-strip-types src/loaders/ft_dispatch.ts",
    "ft:dispatch:reconcile": "node --experimental-strip-types scripts/ft_dispatch_reconcile.ts",
    "ft:dispatch:rls": "node --experimental-strip-types scripts/ft_dispatch_rls_proof.ts",
    "ft:gp:load": "node --experimental-strip-types src/loaders/ft_gp.ts",
    "ft:gp:verify": "node --experimental-strip-types scripts/ft_gp_verify.ts",
    "ft:gp:core": "node --experimental-strip-types src/loaders/ft_gp_core.ts",
    "ft:gp:reconcile": "node --experimental-strip-types scripts/ft_gp_reconcile.ts",
    "ft:gp:parity": "node --experimental-strip-types scripts/ft_gp_parity.ts",
    "ft:gp:rls": "node --experimental-strip-types scripts/ft_gp_settlement_rls_proof.ts",
    "cube:gp": "node --experimental-strip-types scripts/cube_gp_settlement_check.ts",
    "ns:smoke": "node --experimental-strip-types scripts/ns_smoke.ts",
    "ns:backfill": "node --experimental-strip-types src/loaders/ns_settlement.ts",
    "ns:core": "node --experimental-strip-types src/loaders/ns_core.ts",
    "ns:reconcile": "node --experimental-strip-types scripts/ns_line_reconcile.ts",
    "ns:rls": "node --experimental-strip-types scripts/ns_settlement_rls_proof.ts",
    "ns:parity": "node --experimental-strip-types scripts/ns_net_parity.ts",
    "reconcile": "node --experimental-strip-types src/reconcile.ts",
    "schema:diff": "node --experimental-strip-types src/schemaDiff.ts",
    "schema:snapshot": "node --experimental-strip-types src/schemaDiff.ts --init",
    "cube:rls": "node --experimental-strip-types scripts/cube_rls_proof.ts",
    "cube:reconcile": "node --experimental-strip-types scripts/cube_reconcile.ts",
    "cube:grower-name": "node --experimental-strip-types scripts/cube_grower_name_proof.ts",
    "cube:settlement": "node --experimental-strip-types scripts/cube_settlement_check.ts",
    "mcp:server": "node --experimental-strip-types mcp/server.ts",
    "mcp:proof": "node --experimental-strip-types scripts/mcp_proof.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.3"
  }
}
